# =====================================================================
#  Ustoz (data365) — environment template
#  Copy to `.env` for local dev, OR paste into Railway → Variables for prod.
#  Account-agnostic: every value here is a PLACEHOLDER. Generate your OWN
#  secrets (commands below) — never reuse someone else's.
#  Full step-by-step: see DEPLOY.md
# =====================================================================

# ---------------------------------------------------------------------
# 1) CORE SECRETS  — generate fresh, keep private
#    NEXTAUTH_SECRET / INVITE_TOKEN_SECRET:  openssl rand -base64 32
#    DATABASE_ENCRYPTION_KEY / CRON_SECRET:  openssl rand -hex 32
# ---------------------------------------------------------------------
NEXTAUTH_SECRET=__GENERATE__base64_32
DATABASE_ENCRYPTION_KEY=__GENERATE__hex_32      # encrypts stored creds; NEVER change after first deploy or data becomes unreadable
INVITE_TOKEN_SECRET=__GENERATE__base64_32
CRON_SECRET=__GENERATE__hex_32                  # also add as a GitHub repo secret (see DEPLOY.md cron step)

# ---------------------------------------------------------------------
# 2) PUBLIC URL  — all three are the SAME value (your deployed URL).
#    ⚠️ NEXT_PUBLIC_WEB_URL is BUILD-TIME: it is baked into the build,
#       so it MUST be set BEFORE the first build/deploy.
# ---------------------------------------------------------------------
NEXTAUTH_URL=https://your-app.example.com
WEB_URL=https://your-app.example.com
NEXT_PUBLIC_WEB_URL=https://your-app.example.com

# ---------------------------------------------------------------------
# 3) DATABASE (MySQL)
#    Prod (Railway): use a reference to the MySQL plugin -> ${{MySQL.MYSQL_URL}}
#    Local: a mysql:// connection string.
#    For one-off `db:push` / `seed:admin` from your laptop, use the PUBLIC url.
# ---------------------------------------------------------------------
DATABASE_URL=mysql://user:password@host:3306/railway

# ---------------------------------------------------------------------
# 4) STORAGE — Cloudflare R2  (videos, thumbnails, transcripts)
#    ⚠️ KNOWN GOTCHA (cost us a live outage): the server-side S3 client
#       reads CAP_AWS_* from process.env DIRECTLY. The CLOUDFLARE_R2_* ->
#       CAP_AWS_* convenience mapping does NOT reach process.env, so if you
#       set only CLOUDFLARE_R2_*, playback/thumbnails/transcription 500.
#       => SET THE CAP_AWS_* VARS EXPLICITLY (below). Setting both is fine.
#    ENDPOINT = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# ---------------------------------------------------------------------
CAP_AWS_ACCESS_KEY=__YOUR_R2_ACCESS_KEY__
CAP_AWS_SECRET_KEY=__YOUR_R2_SECRET_KEY__
CAP_AWS_ENDPOINT=https://__YOUR_ACCOUNT_ID__.r2.cloudflarestorage.com
CAP_AWS_BUCKET=__YOUR_BUCKET_NAME__
CAP_AWS_REGION=auto
S3_PATH_STYLE=true
# Optional duplicates (used by the validated env object / other code paths):
CLOUDFLARE_R2_ACCOUNT_ID=__YOUR_ACCOUNT_ID__
CLOUDFLARE_R2_ACCESS_KEY=__YOUR_R2_ACCESS_KEY__
CLOUDFLARE_R2_SECRET_KEY=__YOUR_R2_SECRET_KEY__
CLOUDFLARE_R2_BUCKET=__YOUR_BUCKET_NAME__

# ---------------------------------------------------------------------
# 5) FIRST ADMIN  — used once by `pnpm seed:admin`. Change the password
#    after the first login.
# ---------------------------------------------------------------------
INITIAL_ADMIN_EMAIL=admin@your-domain.com
INITIAL_ADMIN_PASSWORD=__STRONG_PASSWORD__

# ---------------------------------------------------------------------
# 6) AI  — Gemini (transcription + summary + chapters + RAG chat)
#    Get a key: https://aistudio.google.com/app/apikey
#    Also set an account-level spend cap in Google AI Studio.
# ---------------------------------------------------------------------
GEMINI_API_KEY=__YOUR_GEMINI_KEY__

# ---------------------------------------------------------------------
# 7) BUILD FLAG  — required for the Docker/standalone build.
#    ⚠️ BUILD-TIME: set BEFORE the first build.
# ---------------------------------------------------------------------
NEXT_PUBLIC_DOCKER_BUILD=true

# ---------------------------------------------------------------------
# 8) OPTIONAL  — leave UNSET unless you actually use them.
#    GOOGLE_CLIENT_ID / SECRET : enable "Sign in with Google".
#    ⚠️ Do NOT set NEXT_PUBLIC_IS_CAP — it turns on billing/paywall gates.
#    Unused upstream integrations (safe to ignore): STRIPE_*, TINYBIRD_*,
#    POSTHOG_*, VERCEL_*, CLOUDFRONT_*, DEEPGRAM/OPENAI/GROQ/REPLICATE,
#    DUB_API_KEY, DISCORD_*_WEBHOOK_URL, SUPERMEMORY_*, MEDIA_SERVER_*.
# ---------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
